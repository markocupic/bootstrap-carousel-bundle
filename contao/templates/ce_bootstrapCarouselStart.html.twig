<div id="{{ identifier }}" class="carousel slide{% if carouselFade %} carousel-fade{% endif %}" data-progress="true" data-bs-interval="{{ carouselInterval }}" data-bs-ride="{{ carouselAutoplay }}" data-bs-keyboard="{{ carouselReactToKeyboard }}" data-bs-pause="{{ carouselPauseOnHover }}" data-bs-wrap="{{ carouselInfiniteCycle }}">
    {% if carouselAddIndicators %}
        <ol class="carousel-indicators">
            {% for counter in arrCount %}
                <button type="button" data-bs-target="#{{ identifier }}" data-bs-slide-to="{{ counter }}" {% if counter == 0 %} class="active" aria-current="true" {% endif %} aria-label="Slide 1"></button>
            {% endfor %}
        </ol>
    {% endif %}
    {% if carouselInterval %}
        <div class="carousel-progress">
            <div class="carousel-progress-bar"></div>
        </div>
    {% endif %}
    <div class="carousel-inner">
        <div class="carousel-item active">
